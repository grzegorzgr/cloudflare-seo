---
// Widok strony encji (place page). Renderuje wyłącznie gotowy model z generatora.
// Zero logiki danych, zero mocków: każda sekcja pojawia się tylko, gdy ma dane.
import type { FeatureView, PageModel } from '@generator';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  model: PageModel;
}

const { model } = Astro.props;

// Prezentacja pojedynczej flagi: boolean -> tak/nie, string -> wartość z danych 1:1.
function renderFlag(value: FeatureView['value']): string {
  if (value === true) return 'tak';
  if (value === false) return 'nie';
  return value;
}
---

<BaseLayout
  title={model.pageTitle}
  description={model.metaDescription}
  canonical={model.canonical}
  keywords={model.keywords}
  jsonLd={model.jsonLd}
>
  <main>
    <article>
      <header>
        <h1>{model.h1}</h1>
        <p class="muted">
          {model.location.city}, {model.location.region}, {model.location.country}
        </p>
        {
          (model.address || model.googleMapsUrl) && (
            <p class="address">
              {model.address && <span>Adres: {model.address.formatted}</span>}
              {model.address && model.googleMapsUrl && <span class="muted"> — </span>}
              {model.googleMapsUrl && (
                <a
                  href={model.googleMapsUrl}
                  rel="noopener nofollow"
                  target="_blank"
                >
                  Zobacz w Google Maps
                </a>
              )}
            </p>
          )
        }
      </header>

      <p>{model.intent}</p>

      {
        model.facts.length > 0 && (
          <section aria-labelledby="opis">
            <h2 id="opis">Opis</h2>
            {model.facts.map((fact) => (
              <p>{fact}</p>
            ))}
          </section>
        )
      }

      {
        model.features.length > 0 && (
          <section aria-labelledby="udogodnienia">
            <h2 id="udogodnienia">Udogodnienia</h2>
            <ul>
              {model.features.map((feature) => (
                <li>
                  {feature.label}: {renderFlag(feature.value)}
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        model.access.length > 0 && (
          <section aria-labelledby="dojazd">
            <h2 id="dojazd">Dojazd</h2>
            <ul>
              {model.access.map((item) => (
                <li>
                  {item.label}: {renderFlag(item.value)}
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        model.faq.length > 0 && (
          <section aria-labelledby="faq">
            <h2 id="faq">FAQ</h2>
            <dl>
              {model.faq.map((item) => (
                <>
                  <dt>{item.q}</dt>
                  <dd>{item.a}</dd>
                </>
              ))}
            </dl>
          </section>
        )
      }

      {
        model.nearby.length > 0 && (
          <section aria-labelledby="podobne">
            <h2 id="podobne">Podobne miejsca</h2>
            <ul>
              {model.nearby.map((place) => (
                <li>
                  <a href={place.href}>{place.label}</a>
                  <span class="muted"> — {place.city}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        model.nearbyPlaces.length > 0 && (
          <section aria-labelledby="w-poblizu">
            <h2 id="w-poblizu">W pobliżu</h2>
            <ul>
              {model.nearbyPlaces.map((place) => (
                <li>
                  <a href={place.href}>{place.label}</a>
                  {place.distanceKm !== null && place.distanceKm !== undefined && (
                    <span class="muted">
                      {' '}—{' '}
                      {place.distanceKm < 1
                        ? `${Math.round(place.distanceKm * 1000)} m`
                        : `${place.distanceKm.toFixed(1)} km`}
                    </span>
                  )}
                  {place.type && (
                    <span class="muted type-badge"> ({place.type})</span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        model.collections.length > 0 && (
          <section aria-labelledby="kolekcje">
            <h2 id="kolekcje">Kolekcje</h2>
            <ul>
              {model.collections.map((col) => (
                <li>
                  <a href={col.href}>{col.label}</a>
                  <span class="muted"> — {col.count} obiektów</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </article>
  </main>
</BaseLayout>
