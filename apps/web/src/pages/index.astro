---
// HOME (GEO GRAPH INDEX NODE) -> "/". Root grafu SEO.
// Sekcje: Regiony / Miasta-huby / Kategorie. Wszystko z /packages/data.
import beaches from '@data/beaches.json';
import parkings from '@data/parkings.json';
import trails from '@data/trails.json';
import cities from '@data/cities.json';
import {
  beachConfig,
  parkingConfig,
  trailConfig,
  buildHomeModel,
  indexCategories,
  type Entity,
} from '@generator';
import { seoConfig } from '@config/seo.config.ts';
import IndexPage from '../components/IndexPage.astro';

const datasets = [
  { entities: beaches as Entity[], config: beachConfig },
  { entities: parkings as Entity[], config: parkingConfig },
  { entities: trails as Entity[], config: trailConfig },
];

const model = buildHomeModel(
  datasets,
  cities as Entity[],
  indexCategories,
  seoConfig.siteUrl,
);
---

<IndexPage {...model} />
