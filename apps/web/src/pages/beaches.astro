---
// INDEX: /beaches -> pelna lista plaz pogrupowana wg regionu.
import beaches from '@data/beaches.json';
import {
  beachConfig,
  buildCategoryIndexModel,
  indexCategories,
  type Entity,
} from '@generator';
import { seoConfig } from '@config/seo.config.ts';
import IndexPage from '../components/IndexPage.astro';

const model = buildCategoryIndexModel(
  beaches as Entity[],
  beachConfig,
  '/beaches/',
  indexCategories,
  seoConfig.siteUrl,
);
---

<IndexPage {...model} />
