---
// Strona cluster (SSG): lista wszystkich parkingow pogrupowana wg regionu -> /parking/.
import parkings from '@data/parkings.json';
import { parkingConfig, buildClusterModel, type Entity } from '@generator';
import { seoConfig } from '@config/seo.config.ts';
import ListingPage from '../../components/ListingPage.astro';

const model = buildClusterModel(parkings as Entity[], parkingConfig, seoConfig.siteUrl);
---

<ListingPage
  title={model.title}
  description={model.description}
  canonical={model.canonical}
  intro={model.intro}
  heading={model.title}
  count={model.count}
  sections={model.sections}
  jsonLd={model.jsonLd}
/>
