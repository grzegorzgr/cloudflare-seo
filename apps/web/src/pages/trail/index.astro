---
// Strona cluster (SSG): lista wszystkich szlakow pogrupowana wg regionu -> /trail/.
import trails from '@data/trails.json';
import { trailConfig, buildClusterModel, type Entity } from '@generator';
import { seoConfig } from '@config/seo.config.ts';
import ListingPage from '../../components/ListingPage.astro';

const model = buildClusterModel(trails as Entity[], trailConfig, seoConfig.siteUrl);
---

<ListingPage
  title={model.title}
  description={model.description}
  canonical={model.canonical}
  intro={model.intro}
  heading={model.title}
  count={model.count}
  sections={model.sections}
  jsonLd={model.jsonLd}
/>
