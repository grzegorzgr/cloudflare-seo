---
// Strona plaży (SSG). Jedna encja z beaches.json = jedna strona /beach/[slug].
// Cała logika pochodzi z packages/generator; ta strona tylko wiąże dane z widokiem.
import beaches from '@data/beaches.json';
import parkings from '@data/parkings.json';
import trails from '@data/trails.json';
import {
  beachConfig,
  parkingConfig,
  trailConfig,
  buildPageModel,
  buildAllCollections,
  findEntityCollections,
  type Entity,
  type CollectionRef,
} from '@generator';
import EntityPage from '../../components/PlacePage.astro';

const _allDatasets = [
  { entities: beaches as Entity[], config: beachConfig },
  { entities: parkings as Entity[], config: parkingConfig },
  { entities: trails as Entity[], config: trailConfig },
];

export function getStaticPaths() {
  const allDatasets = [
    { entities: beaches as Entity[], config: beachConfig },
    { entities: parkings as Entity[], config: parkingConfig },
    { entities: trails as Entity[], config: trailConfig },
  ];
  const collections = buildAllCollections(allDatasets);
  return (beaches as Entity[]).map((entity) => ({
    params: { slug: entity.slug },
    props: { entity, entityCollections: findEntityCollections(entity, beachConfig, collections) },
  }));
}

const { entity, entityCollections } = Astro.props as { entity: Entity; entityCollections: CollectionRef[] };
const model = buildPageModel(entity, beachConfig, beaches as Entity[], _allDatasets, entityCollections);
---

<EntityPage model={model} />
