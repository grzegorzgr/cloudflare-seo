---
// INDEX: /trails -> pelna lista szlakow pogrupowana wg regionu.
import trails from '@data/trails.json';
import {
  trailConfig,
  buildCategoryIndexModel,
  indexCategories,
  type Entity,
} from '@generator';
import { seoConfig } from '@config/seo.config.ts';
import IndexPage from '../components/IndexPage.astro';

const model = buildCategoryIndexModel(
  trails as Entity[],
  trailConfig,
  '/trails/',
  indexCategories,
  seoConfig.siteUrl,
);
---

<IndexPage {...model} />
