---
// Strona cluster regionu (SSG): agreguje wszystkie typy encji dla regionu -> /region/{slug}.
import beaches from '@data/beaches.json';
import parkings from '@data/parkings.json';
import trails from '@data/trails.json';
import {
  beachConfig,
  parkingConfig,
  trailConfig,
  buildRegionModel,
  listRegions,
  type Entity,
} from '@generator';
import { seoConfig } from '@config/seo.config.ts';
import ListingPage from '../../components/ListingPage.astro';

export function getStaticPaths() {
  const datasets = [
    { entities: beaches as Entity[], config: beachConfig },
    { entities: parkings as Entity[], config: parkingConfig },
    { entities: trails as Entity[], config: trailConfig },
  ];
  return listRegions(datasets).map((ref) => ({
    params: { region: ref.slug },
    props: { region: ref.region },
  }));
}

const datasets = [
  { entities: beaches as Entity[], config: beachConfig },
  { entities: parkings as Entity[], config: parkingConfig },
  { entities: trails as Entity[], config: trailConfig },
];

const { region } = Astro.props as { region: string };
const model = buildRegionModel(region, datasets, seoConfig.siteUrl);
---

<ListingPage
  title={model.title}
  description={model.description}
  canonical={model.canonical}
  intro={model.intro}
  heading={model.region}
  count={model.count}
  sections={model.sections}
  jsonLd={model.jsonLd}
/>
