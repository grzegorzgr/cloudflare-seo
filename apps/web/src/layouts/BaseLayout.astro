---
// Bazowy layout SSG. Odpowiada wyłącznie za dokument HTML, meta SEO i JSON-LD.
// Treść strony trafia do <slot />. Brak logiki i brak client-side JS.
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown>;
}

const { title, description, canonical, keywords, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {keywords && keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(', ')} />
    )}
    {canonical && <link rel="canonical" href={canonical} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5388040901928181"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --max-width: 46rem;
    --fg: #1a1a1a;
    --muted: #555;
    --line: #e2e2e2;
    --link: #0b57d0;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.6;
    color: var(--fg);
  }

  body {
    margin: 0;
    padding: 1.5rem 1rem 4rem;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  h1 {
    font-size: 1.9rem;
    line-height: 1.2;
    margin: 0 0 0.25rem;
  }

  h2 {
    font-size: 1.25rem;
    margin: 2rem 0 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--line);
  }

  a {
    color: var(--link);
  }

  ul {
    margin: 0.5rem 0;
    padding-left: 1.25rem;
  }

  dt {
    font-weight: 600;
    margin-top: 0.75rem;
  }

  dd {
    margin: 0 0 0.5rem;
    color: var(--muted);
  }

  .muted {
    color: var(--muted);
  }
</style>
