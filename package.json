{
  "name": "cloudflare-seo",
  "private": true,
  "version": "0.0.1",
  "description": "Deterministyczny system Programmatic SEO: dane -> generacja -> statyczne strony -> Cloudflare Pages.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @cloudflare-seo/web",
    "dev": "npm run dev --workspace @cloudflare-seo/web",
    "preview": "npm run preview --workspace @cloudflare-seo/web"
  }
}
